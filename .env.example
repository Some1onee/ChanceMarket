# ─────────────────────────────────────────────────────────────────────────────
# ChanceMarket — environment template. Copy to .env.local and fill in.
# NEVER commit real secrets. NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ChanceMarket

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local dev: values printed by `pnpm db:start`. Production: project settings.
NEXT_PUBLIC_SUPABASE_URL=https://kfyrvzuvqmhwpdjtyafd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TiS6lxCLTPfh_Dsy_2rmsQ_-4haGltB
# Server-only. Bypasses RLS. Never expose to the browser or client bundles.
SUPABASE_SECRET_KEY=
# Direct Postgres connection string (migrations, integration tests).
SUPABASE_DATABASE_URL=

# ── Payments (interface-driven; "mock" requires no credentials) ──────────────
# Allowed: mock | stripe_connect_stub (structure only — no live provider is
# shipped; see docs/PAYMENTS.md and docs/PROVIDER_APPROVAL_CHECKLIST.md)
PAYMENT_PROVIDER=mock
PAYMENT_PROVIDER_API_KEY=
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me

# ── Transactional email (interface-driven; "log" writes to server logs) ──────
EMAIL_PROVIDER=log
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=no-reply@example.com

# ── Geolocation (interface-driven; "headers" uses proxy/CDN headers) ─────────
GEOLOCATION_PROVIDER=headers
GEOLOCATION_API_KEY=

# ── Identity verification / KYC (interface-driven; "mock" auto-passes in dev) ─
KYC_PROVIDER=mock
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

# ── Internal secrets ─────────────────────────────────────────────────────────
# 32+ byte random strings. Generate: openssl rand -hex 32
APP_ENCRYPTION_KEY=
CRON_SECRET=
INTERNAL_API_SECRET=

# ── Feature flags (coarse kill-switches; the jurisdiction compliance engine
#    still applies on top — a flag can never enable a non-approved territory) ──
ENABLE_REAL_PAYMENTS=false
ENABLE_PAID_ENTRIES=false
ENABLE_FREE_ENTRIES=true
ENABLE_SKILL_COMPETITIONS=true

# ── E2E / integration testing ────────────────────────────────────────────────
# Set to the LOCAL stack only. Integration tests are skipped when unset.
SUPABASE_TEST_URL=
SUPABASE_TEST_SECRET_KEY=
E2E_BASE_URL=http://localhost:3000
